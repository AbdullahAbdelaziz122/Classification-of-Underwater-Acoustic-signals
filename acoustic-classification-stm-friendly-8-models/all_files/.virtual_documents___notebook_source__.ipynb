import os
import zipfile
from pathlib import Path

def flatten_and_zip(source_dir, zip_filename="all_files.zip"):
    """
    Recursively collect all files from source_dir and add them to a zip file
    without preserving directory structure. Duplicate names are resolved by
    using the relative path with separators replaced by underscores.
    """
    source_dir = Path(source_dir).resolve()
    zip_path = source_dir / zip_filename

    # Avoid zipping the zip file itself if it already exists
    if zip_path.exists():
        os.remove(zip_path)

    with zipfile.ZipFile(zip_path, 'w', zipfile.ZIP_DEFLATED) as zf:
        for root, dirs, files in os.walk(source_dir):
            for file in files:
                full_path = Path(root) / file
                # Skip the zip file itself if it appears (shouldn't happen as we removed it)
                if full_path == zip_path:
                    continue

                # Relative path from source_dir
                rel_path = full_path.relative_to(source_dir)
                # Flatten: replace path separators with underscores
                # e.g., "virtual_documents/confusion.png" -> "virtual_documents_confusion.png"
                flat_name = str(rel_path).replace(os.sep, '_')
                zf.write(full_path, arcname=flat_name)

    print(f"✅ All files have been zipped into: {zip_path}")
    print(f"📦 You can download '{zip_filename}' from the file browser.")

# Run the function
flatten_and_zip("/kaggle/working")
